# Copy to .env (root) and fill in.
# Per-app env files live in apps/api/.env and apps/web/.env.local.

# ---------------- Database ----------------
# Local Postgres via docker-compose (see docker-compose.yml)
DATABASE_URL="postgresql://matura:matura@localhost:5432/matura?schema=public"

# ---------------- Redis -------------------
REDIS_URL="redis://localhost:6379"

# ---------------- Object storage (MinIO locally, R2 in prod) ----------------
S3_ENDPOINT="http://localhost:9000"
S3_REGION="auto"
S3_ACCESS_KEY_ID="matura"
S3_SECRET_ACCESS_KEY="matura-secret"
S3_BUCKET="matura-content"
S3_FORCE_PATH_STYLE="true"   # true for MinIO, false for R2
S3_PUBLIC_BASE_URL="http://localhost:9000/matura-content"

# ---------------- Firebase Auth ----------------
# Web (apps/web) — public, NEXT_PUBLIC_*
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""

# API (apps/api) — service account JSON, base64 OR a path
FIREBASE_SERVICE_ACCOUNT_BASE64=""
# OR: FIREBASE_SERVICE_ACCOUNT_PATH="./firebase-service-account.json"

# ---------------- AI providers (deferred) ----------------
# OPENAI_API_KEY=""
# ANTHROPIC_API_KEY=""
# GOOGLE_GENERATIVE_AI_API_KEY=""

# ---------------- Web ----------------
NEXT_PUBLIC_API_URL="http://localhost:4000"

# ---------------- API ----------------
API_PORT="4000"
WEB_ORIGIN="http://localhost:3000"
NODE_ENV="development"
