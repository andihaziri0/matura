{
  "name": "@matura/db",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "db:generate": "node --env-file=../../.env ./node_modules/prisma/build/index.js generate",
    "db:migrate": "node --env-file=../../.env ./node_modules/prisma/build/index.js migrate dev",
    "db:migrate:deploy": "node --env-file=../../.env ./node_modules/prisma/build/index.js migrate deploy",
    "db:reset": "node --env-file=../../.env ./node_modules/prisma/build/index.js migrate reset --force",
    "db:studio": "node --env-file=../../.env ./node_modules/prisma/build/index.js studio",
    "db:seed": "node --env-file=../../.env ./node_modules/tsx/dist/cli.mjs src/seed/index.ts",
    "seed:questions": "node --env-file=../../.env ./node_modules/tsx/dist/cli.mjs src/seed/questions.ts",
    "attach:matura-foto-images": "node --env-file=../../.env ./node_modules/tsx/dist/cli.mjs src/seed/attach-matura-foto-images.ts",
    "diag:foto-counts": "node --env-file=../../.env ./node_modules/tsx/dist/cli.mjs src/diag-foto-counts.ts",
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "tsx src/seed/index.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.717.0",
    "@prisma/client": "^6.1.0"
  },
  "devDependencies": {
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
