# Production environment shape — REFERENCE ONLY.
#
# Real values live in Vercel (web) and Railway (API) dashboards, NEVER in
# this repo. This file documents the keys an operator must set when
# provisioning a prod env. Copy to `.env.production.local` (gitignored)
# only if you need to run the API in prod-like mode locally for debugging.

# ====================================================================
# API (set in Railway → matura-api → Variables)
# ====================================================================

NODE_ENV=production

# Railway sets PORT automatically. Map it here so our env loader picks it up:
API_PORT=${{PORT}}

# Comma-separated CORS allowlist. Wildcards like `https://*.vercel.app`
# match a single DNS label. The prod web app + the Vercel preview wildcard:
WEB_ORIGIN=https://matura.akademiaas.com,https://*.vercel.app

# Neon — POOLED URL (the one with `-pooler` in the host).
# The non-pooled "direct" URL is only used for local migrations/Studio.
DATABASE_URL=postgresql://<user>:<password>@<host>-pooler.<region>.aws.neon.tech/<db>?sslmode=require&channel_binding=require

# Upstash Redis — `rediss://` (TLS).
REDIS_URL=rediss://default:<token>@<host>.upstash.io:6379

# Cloudflare R2 — S3-compatible storage.
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_REGION=auto
S3_ACCESS_KEY_ID=<from R2 API token>
S3_SECRET_ACCESS_KEY=<from R2 API token>
S3_BUCKET=matura-content
S3_FORCE_PATH_STYLE=false
# R2's pub-*.r2.dev URL is already bucket-scoped — do NOT append /matura-content.
# The hash uniquely identifies this bucket; object key follows directly after.
S3_PUBLIC_BASE_URL=https://pub-<hash>.r2.dev

# Firebase Admin SDK — base64-encoded service account JSON.
# Generate via: base64 -i firebase-service-account.json | tr -d '\n'
FIREBASE_SERVICE_ACCOUNT_BASE64=<base64 string>

# Sentry (api server-side). DSN copied from Sentry → matura-api → Settings → Client Keys.
SENTRY_DSN=https://<key>@o<org>.ingest.de.sentry.io/<project-id>
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# ====================================================================
# Web (set in Vercel → matura-web → Settings → Environment Variables)
# Set these for BOTH "Production" and "Preview" environments.
# ====================================================================

NEXT_PUBLIC_API_URL=https://api.matura.akademiaas.com

NEXT_PUBLIC_FIREBASE_API_KEY=<from Firebase prod project config>
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=<projectId>.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=<projectId>
NEXT_PUBLIC_FIREBASE_APP_ID=<appId>

# Sentry (web). DSN copied from Sentry → matura-web → Settings → Client Keys.
NEXT_PUBLIC_SENTRY_DSN=https://<key>@o<org>.ingest.de.sentry.io/<project-id>
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production

# Sentry build-time creds (Vercel build env only, not exposed at runtime).
# Required for source-map upload; without them runtime works but stack traces
# stay minified.
SENTRY_AUTH_TOKEN=<from Sentry → Settings → Auth Tokens>
SENTRY_ORG=<your-sentry-org-slug>
SENTRY_PROJECT=matura-web
